<view class="container">
  <view class="card">
    <view class="card-title">新增营收</view>
    <view class="form-group">
      <view class="form-item">
        <text class="form-label">日期</text>
        <picker mode="date" :value="formData.recordDate" bindchange="onDateChange">
          <view class="picker-value">{{formData.recordDate || '选择日期'}}</view>
        </picker>
      </view>
      <view class="form-item">
        <text class="form-label">渠道</text>
        <picker :value="channelIndex" :range="channels" bindchange="onChannelChange">
          <view class="picker-value">{{channels[channelIndex] || '选择渠道'}}</view>
        </picker>
      </view>
      <view class="form-item">
        <text class="form-label">金额</text>
        <input class="input-field" type="digit" placeholder="请输入金额" value="{{formData.amount}}" bindinput="onAmountInput" />
      </view>
      <view class="form-item">
        <text class="form-label">备注</text>
        <textarea class="input-field" placeholder="选填" value="{{formData.remark}}" bindinput="onRemarkInput" />
      </view>
      <button class="btn-primary" bindtap="submitForm">保存</button>
    </view>
  </view>

  <view class="card">
    <view class="card-header">
      <text class="card-title">营收记录</text>
      <view class="filter-bar">
        <picker mode="date" :value="filterDate" bindchange="onFilterDateChange">
          <view class="filter-btn">{{filterDate || '筛选日期'}}</view>
        </picker>
      </view>
    </view>
    <view class="record-list">
      <view class="record-item" wx:for="{{records}}" wx:key="id" wx:index="index" data-index="{{index}}" bindtap="showDetail">
        <view class="record-info">
          <view class="record-channel">{{getChannelName(item.channel)}}</view>
          <view class="record-date">{{item.recordDate}}</view>
        </view>
        <view class="record-amount">+{{formatMoney(item.amount)}}</view>
      </view>
    </view>
    <view wx:if="{{records.length === 0}}" class="empty-state">
      <text class="empty-text">暂无营收记录</text>
    </view>
  </view>
</view>

<view class="modal-mask" wx:if="{{showModal}}" bindtap="closeModal">
  <view class="modal-content" catchtap="preventClose">
    <view class="modal-title">营收详情</view>
    <view class="modal-body">
      <view class="detail-item">
        <text class="detail-label">日期</text>
        <text class="detail-value">{{selectedRecord.recordDate}}</text>
      </view>
      <view class="detail-item">
        <text class="detail-label">渠道</text>
        <text class="detail-value">{{getChannelName(selectedRecord.channel)}}</text>
      </view>
      <view class="detail-item">
        <text class="detail-label">金额</text>
        <text class="detail-value text-primary font-bold">{{formatMoney(selectedRecord.amount)}}</text>
      </view>
      <view class="detail-item" wx:if="{{selectedRecord.remark}}">
        <text class="detail-label">备注</text>
        <text class="detail-value">{{selectedRecord.remark}}</text>
      </view>
    </view>
    <view class="modal-footer">
      <button class="btn-secondary" bindtap="closeModal">关闭</button>
      <button class="btn-primary" bindtap="deleteRecord">删除</button>
    </view>
  </view>
</view>