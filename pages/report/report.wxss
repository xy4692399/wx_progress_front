.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-date {
  font-size: 26rpx;
  color: #999;
}

.month-selector {
  margin-left: auto;
}

.month-btn {
  padding: 12rpx 24rpx;
  background: #f0f0f0;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #666;
}

.stats-grid {
  display: flex;
  gap: 16rpx;
}

.stat-card {
  flex: 1;
  text-align: center;
  padding: 24rpx 16rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.stat-card.profit-positive {
  background: linear-gradient(135deg, #e6f7ff 0%, #b3e5fc 100%);
}

.stat-card.profit-negative {
  background: linear-gradient(135deg, #fff2e6 0%, #ffe0b2 100%);
}

.stat-value {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.monthly-summary {
  margin-bottom: 30rpx;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.summary-row:last-child {
  border-bottom: none;
}

.summary-row.highlight {
  background: #f8f9fa;
  margin: 0 -30rpx;
  padding: 24rpx 30rpx;
}

.summary-label {
  font-size: 28rpx;
  color: #666;
}

.summary-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.cost-chart {
  margin-top: 20rpx;
}

.chart-title {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.chart-bars {
  display: flex;
  justify-content: space-around;
  align-items: flex-end;
  height: 200rpx;
  padding: 0 20rpx;
}

.bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100rpx;
}

.bar-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.bar-wrapper {
  width: 60rpx;
  height: 150rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  display: flex;
  align-items: flex-end;
  overflow: hidden;
}

.bar {
  width: 100%;
  border-radius: 8rpx;
  transition: height 0.3s;
}

.bar-ingredient {
  background: linear-gradient(180deg, #1890ff 0%, #096dd9 100%);
}

.bar-fixed {
  background: linear-gradient(180deg, #fa8c16 0%, #d46b08 100%);
}

.bar-value {
  font-size: 24rpx;
  color: #666;
  margin-top: 12rpx;
}

.channel-chart {
  margin-top: 20rpx;
}

.pie-chart {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: #f0f0f0;
  margin: 0 auto 20rpx;
  position: relative;
  overflow: hidden;
}

.pie-slice {
  position: absolute;
  width: 100%;
  height: 100%;
  clip-path: polygon(50% 50%, 50% 0%, 100% 0%, 100% 100%, 50% 100%);
}

.channel-legend {
  margin-top: 20rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
}

.legend-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.legend-name {
  flex: 1;
  font-size: 26rpx;
  color: #333;
}

.legend-value {
  font-size: 26rpx;
  color: #999;
}

.daily-list {
  margin-top: 10rpx;
}

.daily-item {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.daily-item:first-child {
  padding-top: 0;
}

.daily-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.daily-date {
  width: 100rpx;
  font-size: 26rpx;
  color: #999;
}

.daily-revenue {
  flex: 1;
  font-size: 26rpx;
  color: #52c41a;
  text-align: right;
  padding-right: 20rpx;
}

.daily-expense {
  width: 140rpx;
  font-size: 26rpx;
  color: #ff4d4f;
  text-align: right;
  padding-right: 20rpx;
}

.daily-profit {
  width: 140rpx;
  font-size: 26rpx;
  font-weight: 500;
  text-align: right;
}