<view class="container">
  <view class="card">
    <view class="header">
      <view class="greeting">
        <text class="greeting-text">今日概览</text>
        <text class="date">{{today}}</text>
      </view>
    </view>
    
    <view class="stats-grid">
      <view class="stat-item">
        <text class="stat-value text-primary font-2xl">{{todayData.totalRevenueFormatted}}</text>
        <text class="stat-label">今日营收</text>
      </view>
      <view class="stat-item">
        <text class="stat-value text-danger font-2xl">{{todayData.totalExpenseFormatted}}</text>
        <text class="stat-label">今日支出</text>
      </view>
    </view>
    
    <view class="profit-card {{profitClass}}">
      <text class="profit-label">今日净利润</text>
      <text class="profit-value font-2xl">{{todayData.netProfitFormatted}}</text>
    </view>
  </view>

  <view class="card">
    <view class="card-title">营收渠道分布</view>
    <view class="channel-list">
      <view class="channel-item" wx:for="{{todayData.channelList}}" wx:key="key">
        <view class="channel-info">
          <text class="channel-name">{{item.name}}</text>
          <text class="channel-amount">{{item.formattedValue}}</text>
        </view>
        <view class="channel-bar">
          <view class="channel-progress" style="width: {{item.percent}}%; background-color: {{item.color}}"></view>
        </view>
      </view>
    </view>
    <view wx:if="{{todayData.channelList.length === 0}}" class="empty-state">
      <text class="empty-text">暂无渠道数据</text>
    </view>
  </view>

  <view class="card">
    <view class="card-title">快捷操作</view>
    <view class="quick-actions">
      <view class="action-item" data-url="/pages/revenue/revenue" bindtap="goToPage">
        <view class="action-icon revenue-icon">+</view>
        <text class="action-text">记营收</text>
      </view>
      <view class="action-item" data-url="/pages/expense/expense" bindtap="goToPage">
        <view class="action-icon expense-icon">-</view>
        <text class="action-text">记支出</text>
      </view>
      <view class="action-item" data-url="/pages/ingredient/ingredient" bindtap="goToPage">
        <view class="action-icon ingredient-icon">+</view>
        <text class="action-text">食材采购</text>
      </view>
      <view class="action-item" data-url="/pages/dish/dish" bindtap="goToPage">
        <view class="action-icon dish-icon">+</view>
        <text class="action-text">菜品毛利</text>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="card-title">本月汇总</view>
    <view class="monthly-summary">
      <view class="summary-item">
        <text class="summary-value">{{monthlyData.totalRevenueFormatted}}</text>
        <text class="summary-label">月营收</text>
      </view>
      <view class="summary-item">
        <text class="summary-value">{{monthlyData.totalExpenseFormatted}}</text>
        <text class="summary-label">月支出</text>
      </view>
      <view class="summary-item">
        <text class="summary-value {{monthlyData.netProfit >= 0 ? 'text-success' : 'text-danger'}}">{{monthlyData.netProfitFormatted}}</text>
        <text class="summary-label">月净利润</text>
      </view>
    </view>
  </view>
</view>